# Gmail — reuse the same OAuth credentials as mortgage-bot-push
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Your email address (where digests and drafts are created)
JOHN_EMAIL=john@libertygroupfunding.com

# Anthropic
ANTHROPIC_API_KEY=

# Digest schedule — comma-separated 24h hours (Eastern) to send digest
DIGEST_HOURS=8,12,16

# How many hours back to scan on each poll (default 1)
SCAN_LOOKBACK_HOURS=1

# Gmail label applied after bot processes an email (excludes from future scans)
GMAIL_PROCESSED_LABEL=broker-assistant-processed

# Set true to skip Gmail writes and email sends during testing
DRY_RUN=false

# Render sync mode
GMAIL_SCAN_SYNC=true
GMAIL_SCAN_TIMEZONE=America/New_York
